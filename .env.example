# ============================================================
# Snag v9.0 — Environment Variables
# ============================================================

# Required: PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost:5432/snag

# Optional: Set to 'false' to disable SSL (local development)
DB_SSL=false

# Required for cover letter generation
ANTHROPIC_API_KEY=sk-ant-...

# Google OAuth (Drive, Gmail, Calendar integration)
# Create credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback
# APP_URL is used to construct the redirect URI if GOOGLE_REDIRECT_URI is not set
APP_URL=http://localhost:3000

# Legacy: Google Drive Apps Script webhook (replaced by OAuth Drive integration)
# DRIVE_WEBHOOK_URL=https://script.google.com/macros/s/.../exec

# JWT signing secret (change in production!)
JWT_SECRET=your-secret-key-at-least-32-characters

# Server port
PORT=3000

# Optional: Restrict CORS origins (comma-separated)
# CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# ============================================================
# Seed script variables (one-time migration from JSON)
# ============================================================
# SEED_EMAIL=you@example.com
# SEED_PASSWORD=your-password
# SEED_NAME=Your Name
